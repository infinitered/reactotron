{
  "name": "reactotron-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "MCP server for Reactotron — lets Claude Code read debug events and send commands to connected apps.",
  "author": "Infinite Red",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/infinitered/reactotron/issues"
  },
  "homepage": "https://github.com/infinitered/reactotron/tree/master/lib/reactotron-mcp",
  "repository": "https://github.com/infinitered/reactotron/tree/master/lib/reactotron-mcp",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rimraf ./dist",
    "test": "jest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "zod": "^4.3.0"
  },
  "peerDependencies": {
    "reactotron-core-contract": "workspace:*",
    "reactotron-core-server": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^18.18.8",
    "get-port-please": "^3.1.1",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "reactotron-core-contract": "workspace:*",
    "reactotron-core-server": "workspace:*",
    "rimraf": "5.0.5",
    "ts-jest": "^29.1.1",
    "tsup": "^8.0.0",
    "typescript": "^5.1.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/*.test.[tj]s"
    ],
    "transform": {
      "^.+\\.ts$": "ts-jest"
    }
  }
}
